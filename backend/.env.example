PORT=8000
NODE_ENV=development
# Production'da Swagger UI varsayılan kapalı. Açmak için: SWAGGER_ENABLED=true
SWAGGER_ENABLED=false
TRUST_PROXY=false

# Database
MONGO_URI=mongodb://localhost:27017/edumathDB

# JWT (Use strong secrets!)
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_here_at_least_64_chars
JWT_REFRESH_SECRET=another_very_long_random_secret_here

# CORS
# FRONTEND_URL is the primary deployed frontend origin
FRONTEND_URL=http://localhost:5173
# Additional allowed origins, comma-separated
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting (sadece NODE_ENV=production iken uygulanır; yerelde 429 almamak için NODE_ENV=development bırakın)
# Üretimde acil durumda limiti kapatmak için (önerilmez): RATE_LIMIT_DISABLED=true
RATE_LIMIT_DISABLED=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Auth-specific rate limiting (login/signup)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
AUTH_SLOW_LOG_MS=800
AUTH_DEBUG_TIMING=false

# Logging
LOG_LEVEL=info

# Error monitoring (optional — leave empty to disable)
# SENTRY_DSN=https://...@sentry.io/...

# Pre-deploy smoke (optional credentials)
# SMOKE_API_URL=http://localhost:8000
# SMOKE_STUDENT_EMAIL=student@edumath.local
# SMOKE_STUDENT_PASSWORD=password123

# Password hashing
BCRYPT_ROUNDS=12

# AI: local (varsayılan, harici API yok) | gemini | ollama
AI_PROVIDER=local

# Akıllı yapıştır — sharp diyagram kırpma (opsiyonel)
# CROP_GAP_THRESHOLD=0.045
# CROP_GAP_MIN_ROWS=5
# CROP_MIN_BAND_ROWS=10
# CROP_PADDING_PX=8
ML_WEAK_TOPIC_THRESHOLD=0.55

# Python ML mikroservisi (ml-service/) — zayıf konu analizi
# Yerel: cd ml-service && python main.py  →  http://localhost:8100
ML_SERVICE_URL=http://localhost:8100
ML_SERVICE_API_KEY=
ML_SERVICE_TIMEOUT_MS=8000

# Google AI Studio (yalnızca AI_PROVIDER=gemini iken)
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_COMPLEX_MODEL=gemini-2.0-flash
# GEMINI_GOOGLE_GROUNDING=0

# Yerel Ollama (AI_PROVIDER=ollama)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# Object storage: local | cloudinary | gdrive | r2 | s3
STORAGE_PROVIDER=local

# Google Drive (STORAGE_PROVIDER=gdrive) — Banking ile aynı service account yapısı
# backend/gcp-service-account.json (Git'e eklemeyin) veya Render'da JSON string
GOOGLE_DRIVE_CREDENTIALS_JSON=./gcp-service-account.json
GOOGLE_DRIVE_IMAGES_FOLDER_ID=
GOOGLE_DRIVE_PATTERNS_FOLDER_ID=
GOOGLE_DRIVE_PUBLIC=true
# Kişisel Gmail Drive için OAuth (service account yükleyemez):
# GOOGLE_DRIVE_OAUTH_CLIENT_ID=
# GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
# GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=
# Workspace domain delegation:
# GOOGLE_DRIVE_IMPERSONATE_EMAIL=you@yourdomain.com

# Cloudinary (STORAGE_PROVIDER=cloudinary) — https://console.cloudinary.com/app/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# R2 / S3 (STORAGE_PROVIDER=r2 veya s3)
S3_BUCKET_NAME=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public CDN/base URL, for example: https://pub-xxxx.r2.dev or https://cdn.example.com
S3_PUBLIC_BASE_URL=
# Set true only if your provider requires path-style URLs
S3_FORCE_PATH_STYLE=false

# Dev convenience
# Automatically approve newly registered users (skip admin approval)
AUTO_APPROVE_USERS=false

# PostgreSQL (SQL path)
# Example for local Docker: postgres://user:password@localhost:5432/edumath
# (MongoDB only) Remove Postgres-related variables if previously added