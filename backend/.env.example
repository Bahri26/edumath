PORT=8000
NODE_ENV=development
TRUST_PROXY=false

# Database
MONGO_URI=mongodb://localhost:27017/edumathDB

# JWT (Use strong secrets!)
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_here_at_least_64_chars
JWT_REFRESH_SECRET=another_very_long_random_secret_here

# CORS
# FRONTEND_URL is the primary deployed frontend origin
FRONTEND_URL=http://localhost:5173
# Additional allowed origins, comma-separated
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting (sadece NODE_ENV=production iken uygulanır; yerelde 429 almamak için NODE_ENV=development bırakın)
# Üretimde acil durumda limiti kapatmak için (önerilmez): RATE_LIMIT_DISABLED=true
RATE_LIMIT_DISABLED=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Auth-specific rate limiting (login/signup)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
AUTH_SLOW_LOG_MS=800
AUTH_DEBUG_TIMING=false

# Logging
LOG_LEVEL=info

# Password hashing
BCRYPT_ROUNDS=12

# AI: local (varsayılan, harici API yok) | gemini | ollama
AI_PROVIDER=local

# Akıllı yapıştır — sharp diyagram kırpma (opsiyonel)
# CROP_GAP_THRESHOLD=0.045
# CROP_GAP_MIN_ROWS=5
# CROP_MIN_BAND_ROWS=10
# CROP_PADDING_PX=8
ML_WEAK_TOPIC_THRESHOLD=0.55

# Google AI Studio (yalnızca AI_PROVIDER=gemini iken)
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_COMPLEX_MODEL=gemini-2.0-flash
# GEMINI_GOOGLE_GROUNDING=0

# Yerel Ollama (AI_PROVIDER=ollama)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# Object storage (R2/S3 compatible)
# local | r2 | s3
STORAGE_PROVIDER=local
S3_BUCKET_NAME=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public CDN/base URL, for example: https://pub-xxxx.r2.dev or https://cdn.example.com
S3_PUBLIC_BASE_URL=
# Set true only if your provider requires path-style URLs
S3_FORCE_PATH_STYLE=false

# Dev convenience
# Automatically approve newly registered users (skip admin approval)
AUTO_APPROVE_USERS=false

# PostgreSQL (SQL path)
# Example for local Docker: postgres://user:password@localhost:5432/edumath
# (MongoDB only) Remove Postgres-related variables if previously added