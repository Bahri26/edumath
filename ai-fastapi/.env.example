# AI Service Configuration
PORT=8001
HOST=0.0.0.0
DEBUG=True

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
# Alternatif: gpt-3.5-turbo (daha ekonomik)

# MongoDB (Backend ile aynı veritabanı veya ayrı)
MONGODB_URI=mongodb://localhost:27017/edumath_ai

# JWT Secret (Backend ile aynı olmalı - token doğrulama için)
JWT_SECRET=your_jwt_secret_key_same_as_backend

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=60
MAX_REQUESTS_PER_HOUR=1000

# Cache
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=False

# Model Settings
MAX_TOKENS=2000
TEMPERATURE=0.7

# Backend Service URL
BACKEND_URL=http://localhost:8000

# Logging
LOG_LEVEL=INFO
