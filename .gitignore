# =============================
backend/uploads/*
!backend/uploads/patterns/
!backend/uploads/patterns/**
!backend/uploads/seed-pattern-bank/
!backend/uploads/seed-pattern-bank/.gitkeep
!backend/uploads/generated/
!backend/uploads/generated/.gitkeep
!backend/uploads/seed-math-bank/
!backend/uploads/seed-math-bank/.gitkeep
!backend/uploads/pattern-templates/
!backend/uploads/pattern-templates/.gitkeep
!backend/uploads/temp/
